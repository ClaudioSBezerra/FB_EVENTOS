{
  "name": "fb-eventos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0 <10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepare": "husky",
    "check:db": "bash scripts/ci/check-no-embedded-db.sh",
    "check:legacy": "bash scripts/ci/check-no-legacy-names.sh",
    "check:drizzle": "bash scripts/ci/check-no-drizzle-push.sh",
    "check:nextjs": "bash scripts/ci/check-nextjs-version.sh",
    "check:all": "pnpm run check:db && pnpm run check:legacy && pnpm run check:drizzle && pnpm run check:nextjs",
    "db:up": "docker compose -f docker/compose.yml up -d",
    "db:down": "docker compose -f docker/compose.yml down",
    "db:setup-roles": "bash scripts/db/setup-roles.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local src/db/migrate.ts",
    "db:check": "drizzle-kit check",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "worker:dev": "tsx --env-file=.env.local scripts/jobs/start-worker.ts",
    "worker:start": "node dist-worker/scripts/jobs/start-worker.js",
    "build:worker": "tsc -p tsconfig.worker.json",
    "docker:build:local": "docker build --build-arg APP_VERSION=$(node -p \"require('./package.json').version\") -t fb-eventos-web:$(node -p \"require('./package.json').version\") -f docker/Dockerfile .",
    "docker:build:worker:local": "docker build --build-arg APP_VERSION=$(node -p \"require('./package.json').version\") -t fb-eventos-worker:$(node -p \"require('./package.json').version\") -f docker/Dockerfile.worker ."
  },
  "dependencies": {
    "@hookform/resolvers": "~5.4.0",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@react-pdf/renderer": "4.5.1",
    "@sentry/nextjs": "~10.57.0",
    "better-auth": "1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "graphile-worker": "~0.16.6",
    "konva": "~10.3.0",
    "lucide-react": "^1.17.0",
    "minio": "~8.0.7",
    "next": "~15.5.19",
    "next-safe-action": "~8.5.4",
    "pdfjs-dist": "~4.10.38",
    "pino": "~10.3.1",
    "postgres": "3.4.9",
    "react": "~19.2.7",
    "react-dom": "~19.2.7",
    "react-hook-form": "~7.78.0",
    "react-konva": "~19.2.0",
    "resend": "~6.12.4",
    "tailwind-merge": "^3.6.0",
    "use-image": "~1.1.4",
    "zod": "~4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@playwright/test": "~1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "~6.0.2",
    "@vitest/ui": "^4.1.8",
    "drizzle-kit": "0.31.10",
    "husky": "^9.1.7",
    "msw": "~2.x",
    "nodemailer": "^8.0.11",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "~5.6.0",
    "vitest": "~4.1.8"
  }
}
