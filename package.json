{
  "name": "fb-eventos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=9.0.0 <10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepare": "husky",
    "check:db": "bash scripts/ci/check-no-embedded-db.sh",
    "check:legacy": "bash scripts/ci/check-no-legacy-names.sh",
    "check:drizzle": "bash scripts/ci/check-no-drizzle-push.sh",
    "check:nextjs": "bash scripts/ci/check-nextjs-version.sh",
    "check:all": "pnpm run check:db && pnpm run check:legacy && pnpm run check:drizzle && pnpm run check:nextjs",
    "db:up": "docker compose -f docker/compose.yml up -d",
    "db:down": "docker compose -f docker/compose.yml down",
    "db:setup-roles": "bash scripts/db/setup-roles.sh",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx --env-file=.env.local src/db/migrate.ts",
    "db:check": "drizzle-kit check",
    "docker:build:local": "docker build --build-arg APP_VERSION=$(node -p \"require('./package.json').version\") -t fb-eventos-web:$(node -p \"require('./package.json').version\") -f docker/Dockerfile ."
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "~15.5.19",
    "postgres": "3.4.9",
    "react": "~19.2.7",
    "react-dom": "~19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "0.31.10",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "~5.6.0"
  }
}
