# =============================================================================
# FB_EVENTOS — Production env manifest (committed placeholders only)
# Production secrets live in Coolify UI — this file documents the manifest, not values.
# Key parity with .env.example is enforced by Task 1 acceptance test.
# =============================================================================

# ====== Database ======
# Runtime (fb_eventos_app role — DML only, NO BYPASSRLS) — see Plan 03
DATABASE_URL=postgresql://fb_app_user:CHANGE_ME@db.internal:5432/fb_eventos
# Migrations (fb_eventos_migrator role — DDL only) — see Plan 03
DATABASE_MIGRATOR_URL=postgresql://fb_migrator:CHANGE_ME@db.internal:5432/fb_eventos

# ====== Auth (Plan 04) ======
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_-hex_32
BETTER_AUTH_URL=https://CHANGE_ME

# ====== Email transport — SMTP via nodemailer (Plan 04 + 01-08 D-14 swap) ======
# Operator-managed SMTP server (Hostinger, postfix, etc). REQUIRED in production.
# Pick SMTP_PORT=587 with SMTP_SECURE=false for STARTTLS, OR
# SMTP_PORT=465 with SMTP_SECURE=true for implicit TLS.
SMTP_HOST=smtp.CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_SECURE=false
SMTP_FROM="FB_EVENTOS <no-reply@eventos.fbtax.cloud>"

# ====== Object Storage (Phase 1) ======
# Internal endpoint — Coolify-internal hostname (cleartext intra-network).
# Browsers NEVER hit this; web/worker containers talk to it directly.
MINIO_ENDPOINT=fb-eventos-minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_USE_SSL=false
MINIO_DEFAULT_BUCKET=fb-eventos
# Public endpoint embedded in pre-signed URLs delivered to the browser.
# MUST be externally resolvable + TLS-terminated by Traefik.
MINIO_PUBLIC_ENDPOINT=https://CHANGE_ME
# Root creds — set in Coolify env UI ONLY. NEVER commit values.
MINIO_ROOT_USER=CHANGE_ME
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_BROWSER_REDIRECT_URL=https://CHANGE_ME

# ====== Observability (Plan 06) ======
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=CHANGE_ME
LOG_LEVEL=info

# ====== Pagar.me v5 (Phase 1, Plan 01-06 + Phase 2, Plan 02-05) ======
PAGARME_SECRET_KEY=sk_CHANGE_ME
PAGARME_ENV=production
PAGARME_WEBHOOK_USER=CHANGE_ME
PAGARME_WEBHOOK_PASS=CHANGE_ME
# HMAC signing secret for webhook verification (Phase 2, Plan 02-05 — AM-02).
# Obtain from: Pagar.me dashboard → Configurações → Webhooks → Signing Secret.
# See docs/adr/0005-webhook-hmac-strategy.md for the HMAC contract.
# ⚠️ PROBE PENDING: Run tests/probes/pagarme-hmac-header-probe.test.ts to confirm.
PAGARME_WEBHOOK_SIGNING_SECRET=CHANGE_ME

# ====== App ======
NEXT_PUBLIC_APP_URL=https://CHANGE_ME
NODE_ENV=production
TZ=America/Sao_Paulo
