{
  // NOTE: `pnpm build:worker` is no longer used by the production runtime
  // (the Coolify deploy runs the source .ts files directly via tsx — see
  // docker/Dockerfile worker-runner stage). This config is kept for the
  // `pnpm typecheck:worker` story so worker-only TS errors still surface
  // separately from the Next.js typecheck — only `noEmit: true` matters.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-worker",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "jsx": "preserve",
    "plugins": []
  },
  "include": [
    "src/jobs/**/*",
    "scripts/jobs/**/*",
    "src/lib/**/*",
    "src/db/**/*",
    "src/auth/server.ts"
  ],
  "exclude": [
    "src/app/**/*",
    "src/components/**/*",
    "src/middleware.ts",
    "src/instrumentation.ts",
    "src/instrumentation-node.ts",
    "node_modules",
    "dist-worker",
    ".next",
    "tests/**/*",
    "**/*.test.ts"
  ]
}
