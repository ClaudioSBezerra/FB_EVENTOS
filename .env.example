# =============================================================================
# FB_EVENTOS — Development env manifest (committed placeholders only)
# Copy to .env.local for local development (.env.local is gitignored).
# Production values live in Coolify UI — see .env.production.example for manifest.
# Key parity with .env.production.example is enforced by Task 1 acceptance test.
# =============================================================================

# ====== Database ======
# Runtime (fb_eventos_app role — DML only, NO BYPASSRLS) — see Plan 03
DATABASE_URL=postgresql://fb_app_user:CHANGE_ME@localhost:5432/fb_eventos_dev
# Migrations (fb_eventos_migrator role — DDL only, CI/deploy step) — see Plan 03
DATABASE_MIGRATOR_URL=postgresql://fb_migrator:CHANGE_ME@localhost:5432/fb_eventos_dev

# ====== Auth (Plan 04) ======
# Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=GENERATE_WITH_openssl_rand_-hex_32
BETTER_AUTH_URL=http://localhost:3000

# ====== Email (Plan 04) ======
RESEND_API_KEY=re_CHANGE_ME

# ====== Object Storage (Phase 1) ======
# Internal endpoint — used server-side by the web/worker containers.
# In Coolify production this is the internal hostname (e.g. fb-eventos-minio).
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_USE_SSL=false
MINIO_DEFAULT_BUCKET=fb-eventos
# Public endpoint embedded in pre-signed URLs delivered to the browser.
# Leave blank in dev (single host); set to https://minio.eventos.fbtax.cloud
# in Coolify production. See docker/coolify/minio.service.md.
MINIO_PUBLIC_ENDPOINT=
# Local-only root creds for the docker compose service (NOT used by the app —
# the app uses MINIO_ACCESS_KEY / MINIO_SECRET_KEY above). Leaving these
# empty falls back to the compose-defined defaults.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BROWSER_REDIRECT_URL=

# ====== Observability (Plan 06) ======
SENTRY_DSN=https://CHANGE_ME@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=CHANGE_ME
LOG_LEVEL=info

# ====== ZapSign (Phase 1, Plan 01-05 — D-01/D-02/D-03) ======
# Bearer token issued by sandbox/production dashboard.
# Sandbox:    https://sandbox.app.zapsign.co/ → Configurações > Integrações > API
# Production: https://app.zapsign.co/        → Configurações > Integrações > API
ZAPSIGN_TOKEN=CHANGE_ME
# 'sandbox' (D-03 default in dev/staging) | 'production'. Determines which
# REST API base URL the client targets — no `sandbox=true` flag in payload.
ZAPSIGN_ENV=sandbox
# Basic Auth credentials for the webhook callback at /api/webhooks/zapsign.
# Configure the SAME pair in the ZapSign dashboard when registering the
# webhook URL (Phase 1; Phase 2 may layer HMAC + outbox).
# Webhook URL (production): https://eventos.fbtax.cloud/api/webhooks/zapsign
ZAPSIGN_WEBHOOK_USER=CHANGE_ME
ZAPSIGN_WEBHOOK_PASS=CHANGE_ME

# ====== Pagar.me v5 (Phase 1, Plan 01-06 — D-14 sandbox→production gate) ======
# Secret key. The PREFIX is the environment switch — Pagar.me v5 uses one
# base URL (`https://api.pagar.me/core/v5`) for both sandbox and production.
#   Sandbox:    sk_test_...
#   Production: sk_...
# Get it at https://dashboard.pagar.me → Configurações → API.
PAGARME_SECRET_KEY=sk_test_CHANGE_ME
# Diagnostic-only flag — does NOT change the API URL. Asserted in health
# checks / logs so an operator can spot a sandbox key in production deploy.
PAGARME_ENV=sandbox
# Basic Auth credentials configured in the Pagar.me dashboard when
# registering the webhook URL. Configure the SAME pair on both sides.
# Webhook URL (production): https://eventos.fbtax.cloud/api/webhooks/pagarme
PAGARME_WEBHOOK_USER=CHANGE_ME
PAGARME_WEBHOOK_PASS=CHANGE_ME

# ====== App ======
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
TZ=America/Sao_Paulo
